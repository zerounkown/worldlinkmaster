@using WorldLinkMaster.Web.Models
@model Order
@{
    ViewData["Title"] = Localizer["Order #{0}", Model.Id];
}

<div class="page-banner">
    <div class="container"><h1>@Localizer["Order #{0}", Model.Id]</h1></div>
</div>

<div class="container mb-5">
    <p><span class="badge badge-status-@Model.Status.ToString().ToLower()">@Localizer[Model.Status.ToString()]</span> &middot; @Localizer["Placed {0}", Model.OrderDate.ToLocalTime().ToString("MMM d, yyyy")]</p>
    <div class="row">
        <div class="col-12 col-md-7">
            <div class="table-responsive">
            <table class="table">
                <thead><tr><th>@Localizer["Product"]</th><th>@Localizer["Options"]</th><th>@Localizer["Price"]</th><th>@Localizer["Qty"]</th><th>@Localizer["Total"]</th></tr></thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td class="text-muted small">@item.Color @(!string.IsNullOrEmpty(item.Color) && !string.IsNullOrEmpty(item.Size) ? " / " : "") @item.Size</td>
                            <td>@item.UnitPrice.ToDisplayCurrency()</td>
                            <td>@item.Quantity</td>
                            <td>@item.LineTotal.ToDisplayCurrency()</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
        <div class="col-12 col-md-5">
            <div class="summary-box">
                <h4>@Localizer["Summary"]</h4>
                <div class="d-flex justify-content-between mb-2"><span>@Localizer["Subtotal"]</span><span>@Model.Subtotal.ToDisplayCurrency()</span></div>
                <div class="d-flex justify-content-between mb-2"><span>@Localizer["Shipping"]</span><span>@(Model.ShippingCost == 0 ? Localizer["Free"].Value : Model.ShippingCost.ToDisplayCurrency())</span></div>
                <hr />
                <div class="d-flex justify-content-between fw-bold"><span>@Localizer["Total"]</span><span>@Model.Total.ToDisplayCurrency()</span></div>
                <hr />
                <p class="mb-0">@Localizer["Shipping to:"]<br />@Model.ShippingName<br />@Model.ShippingAddress<br />@Model.ShippingCity, @Model.ShippingState @Model.ShippingZip</p>
            </div>
        </div>
    </div>
    <a class="mt-3 d-inline-block" asp-action="Index">&larr; @Localizer["Back to My Orders"]</a>
</div>
