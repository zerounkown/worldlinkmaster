@using WorldLinkMaster.Web.Models
@model Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="page-banner">
    <div class="container"><h1>Order #@Model.Id</h1></div>
</div>

<div class="container mb-5">
    <p><span class="badge badge-status-@Model.Status.ToString().ToLower()">@Model.Status</span> &middot; Placed @Model.OrderDate.ToLocalTime().ToString("MMM d, yyyy")</p>
    <div class="row">
        <div class="col-12 col-md-7">
            <div class="table-responsive">
            <table class="table">
                <thead><tr><th>Product</th><th>Options</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td class="text-muted small">@item.Color @(!string.IsNullOrEmpty(item.Color) && !string.IsNullOrEmpty(item.Size) ? " / " : "") @item.Size</td>
                            <td>@item.UnitPrice.ToAed()</td>
                            <td>@item.Quantity</td>
                            <td>@item.LineTotal.ToAed()</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
        <div class="col-12 col-md-5">
            <div class="summary-box">
                <h4>Summary</h4>
                <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><span>@Model.Subtotal.ToAed()</span></div>
                <div class="d-flex justify-content-between mb-2"><span>Shipping</span><span>@(Model.ShippingCost == 0 ? "Free" : Model.ShippingCost.ToAed())</span></div>
                <hr />
                <div class="d-flex justify-content-between fw-bold"><span>Total</span><span>@Model.Total.ToAed()</span></div>
                <hr />
                <p class="mb-0">Shipping to:<br />@Model.ShippingName<br />@Model.ShippingAddress<br />@Model.ShippingCity, @Model.ShippingState @Model.ShippingZip</p>
            </div>
        </div>
    </div>
    <a class="mt-3 d-inline-block" asp-action="Index">&larr; Back to My Orders</a>
</div>
