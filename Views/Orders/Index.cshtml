@using WorldLinkMaster.Web.Models
@model List<Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="page-banner">
    <div class="container"><h1>My Orders</h1></div>
</div>

<div class="container mb-5">
    @if (Model.Count == 0)
    {
        <p>You haven't placed any orders yet. <a asp-controller="Products" asp-action="Index">Start shopping</a>.</p>
    }
    else
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.OrderDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                        <td><span class="badge badge-status-@order.Status.ToString().ToLower()">@order.Status</span></td>
                        <td>@order.Total.ToAed()</td>
                        <td><a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
