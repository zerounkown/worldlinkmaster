@using WorldLinkMaster.Web.Models
@model List<Order>
@{
    ViewData["Title"] = Localizer["My Orders"];
}

<div class="page-banner">
    <div class="container"><h1>@Localizer["My Orders"]</h1></div>
</div>

<div class="container mb-5">
    @if (Model.Count == 0)
    {
        <p>@Localizer["You haven't placed any orders yet."] <a asp-controller="Products" asp-action="Index">@Localizer["Start shopping"]</a>.</p>
    }
    else
    {
        <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>@Localizer["Order #"]</th>
                    <th>@Localizer["Date"]</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Total"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.OrderDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                        <td><span class="badge badge-status-@order.Status.ToString().ToLower()">@Localizer[order.Status.ToString()]</span></td>
                        <td>@order.Total.ToDisplayCurrency()</td>
                        <td><a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">@Localizer["View"]</a></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
