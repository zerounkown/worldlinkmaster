@using Microsoft.AspNetCore.Identity
@using WorldLinkMaster.Web.Extensions
@using WorldLinkMaster.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var avatarUrl = currentUser.AvatarUrl();
}

<div class="account-menu dropdown">
    @if (SignInManager.IsSignedIn(User))
    {
        <button class="account-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="@Localizer["Hi, {0}", User.Identity?.Name?.Split('@')[0] ?? ""]">
            @if (avatarUrl != null)
            {
                <img src="@avatarUrl" alt="" class="account-avatar-sm" />
            }
            else
            {
                <i class="bi bi-person-circle"></i>
            }
            <span class="account-label">@Localizer["Hi, {0}", User.Identity?.Name?.Split('@')[0] ?? ""]</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end account-dropdown">
            <li><a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-badge"></i> @Localizer["My Profile"]</a></li>
            <li><a class="dropdown-item" asp-area="" asp-controller="Orders" asp-action="Index">@Localizer["My Orders"]</a></li>
            <li><a class="dropdown-item" asp-area="" asp-controller="Coupons" asp-action="Index"><i class="bi bi-ticket-perforated"></i> @Localizer["My Coupons"]</a></li>
            <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">@Localizer["Account Settings"]</a></li>
            @if (User.IsInRole("Admin"))
            {
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index">@Localizer["Admin Dashboard"]</a></li>
            }
            @if (User.IsInRole("Support") && !User.IsInRole("Admin"))
            {
                <li><a class="dropdown-item" asp-area="Support" asp-controller="Conversations" asp-action="Index">@Localizer["Support Console"]</a></li>
            }
            @if (User.IsInRole("Merchant"))
            {
                <li><a class="dropdown-item" asp-area="Merchant" asp-controller="Home" asp-action="Index">@Localizer["Merchant Dashboard"]</a></li>
            }
            else
            {
                <li><a class="dropdown-item" asp-area="" asp-controller="MerchantOnboarding" asp-action="Apply">@Localizer["Sell on World Link Master"]</a></li>
            }
            @if (User.IsInRole("Wholesale"))
            {
                <li><a class="dropdown-item" asp-area="" asp-controller="Wholesale" asp-action="Index">@Localizer["Trade Catalog"]</a></li>
            }
            else
            {
                <li><a class="dropdown-item" asp-area="" asp-controller="Wholesale" asp-action="Apply">@Localizer["Join Trade Program"]</a></li>
            }
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item">@Localizer["Log out"]</button>
                </form>
            </li>
        </ul>
    }
    else
    {
        <a class="account-toggle" asp-area="Identity" asp-page="/Account/Login" title="@Localizer["Sign In"]">
            <i class="bi bi-person-circle"></i>
            <span class="account-label">@Localizer["Sign In"]</span>
        </a>
    }
</div>
