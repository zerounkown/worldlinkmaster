@using WorldLinkMaster.Web.Extensions
@using WorldLinkMaster.Web.Models
@model ApplicationUser
@{
    ViewData["Title"] = Localizer["My Profile"];
    var avatarUrl = Model.AvatarUrl();
    var fullName = $"{Model.FirstName} {Model.LastName}".Trim();
}

<div class="page-banner">
    <div class="container"><h1>@Localizer["My Profile"]</h1></div>
</div>

<div class="container mb-5">
    @if (TempData["ProfileMessage"] != null)
    {
        <div class="alert alert-info">@TempData["ProfileMessage"]</div>
    }

    <div class="row justify-content-center">
        <div class="col-12 col-md-6">
            <div class="summary-box text-center">
                @if (avatarUrl != null)
                {
                    <img src="@avatarUrl" alt="@Localizer["Profile picture"]" class="profile-avatar-lg" />
                }
                else
                {
                    <div class="profile-avatar-lg profile-avatar-placeholder">
                        <i class="bi bi-person-fill"></i>
                    </div>
                }

                <h4 class="mt-3 mb-0">@(string.IsNullOrWhiteSpace(fullName) ? Model.Email : fullName)</h4>
                <p class="text-muted">@Model.Email</p>

                <form asp-controller="Profile" asp-action="UploadPicture" method="post" enctype="multipart/form-data" class="mt-3">
                    <div class="mb-3">
                        <input type="file" name="file" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp" required />
                        <div class="form-text">@Localizer["JPG, PNG, GIF, or WEBP — 3 MB max."]</div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload"></i> @(avatarUrl != null ? Localizer["Change Picture"] : Localizer["Upload Picture"])
                    </button>
                </form>

                @if (avatarUrl != null)
                {
                    <form asp-controller="Profile" asp-action="RemovePicture" method="post" class="mt-2">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash"></i> @Localizer["Remove Picture"]
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
