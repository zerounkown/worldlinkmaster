@using WorldLinkMaster.Web.Models
@{
    ViewData["Title"] = Localizer["New Arrivals"];
    var newArrivals = ViewBag.NewArrivals as List<Product> ?? new List<Product>();
    var specials = ViewBag.Specials as List<Product> ?? new List<Product>();
}

<div class="page-banner">
    <div class="container">
        <h1>@Localizer["New Arrivals"]</h1>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-12 col-lg-6 mb-4">
            <div class="section-title">
                <h2>@Localizer["New Arrivals"]</h2>
                <a asp-action="Index">@Localizer["View All"] &rarr;</a>
            </div>
            @if (newArrivals.Count == 0)
            {
                <p>@Localizer["No products found. Try a different category or search term."]</p>
            }
            else
            {
                <div class="product-grid">
                    @foreach (var product in newArrivals)
                    {
                        <partial name="_ProductCard" model="product" />
                    }
                </div>
            }
        </div>
        <div class="col-12 col-lg-6 mb-4">
            <div class="section-title">
                <h2>@Localizer["Specials"]</h2>
                <a asp-action="Index">@Localizer["View All"] &rarr;</a>
            </div>
            @if (specials.Count == 0)
            {
                <p>@Localizer["No products found. Try a different category or search term."]</p>
            }
            else
            {
                <div class="product-grid">
                    @foreach (var product in specials)
                    {
                        <partial name="_ProductCard" model="product" />
                    }
                </div>
            }
        </div>
    </div>
</div>
