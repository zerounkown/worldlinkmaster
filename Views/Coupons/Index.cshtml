@using WorldLinkMaster.Web.Models
@model List<Coupon>
@{
    ViewData["Title"] = "My Coupons";
    var today = DateTime.UtcNow;
}

<div class="page-banner">
    <div class="container"><h1>My Coupons</h1></div>
</div>

<div class="container mb-5">
    @if (Model.Count == 0)
    {
        <p>You don't have any coupons yet. Keep shopping &mdash; every 10th order earns you 50% off, and new perks show up here automatically.</p>
    }
    else
    {
        <div class="coupon-grid">
            @foreach (var coupon in Model)
            {
                var expired = coupon.ExpiresAt.HasValue && coupon.ExpiresAt.Value < today;
                var status = coupon.IsUsed ? "Used" : expired ? "Expired" : "Available";
                var statusClass = coupon.IsUsed ? "coupon-used" : expired ? "coupon-expired" : "coupon-available";
                var sourceLabel = coupon.Source == CouponSource.Welcome ? "Welcome Gift" : "Loyalty Reward";
                <div class="coupon-card @statusClass">
                    <div class="coupon-card-left">
                        <span class="coupon-discount">@coupon.DiscountPercent.ToString("0.##")%</span>
                        <span class="coupon-off">OFF</span>
                    </div>
                    <div class="coupon-card-right">
                        <span class="coupon-source">@sourceLabel</span>
                        <span class="coupon-code">@coupon.Code</span>
                        <span class="coupon-status-badge">@status</span>
                        @if (coupon.ExpiresAt.HasValue)
                        {
                            <span class="coupon-expiry">
                                @(coupon.IsUsed ? $"Used {coupon.UsedAt:MMM d, yyyy}" : $"Expires {coupon.ExpiresAt:MMM d, yyyy}")
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
