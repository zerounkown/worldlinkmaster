@using WorldLinkMaster.Web.Models
@model List<Product>
@{
    ViewData["Title"] = "Trade Catalog";
}

<div class="page-banner">
    <div class="container"><h1>Trade Catalog</h1><p class="mb-0">Wholesale pricing for approved trade accounts.</p></div>
</div>

<div class="container mb-5">
    @if (TempData["CartMessage"] != null)
    {
        <div class="alert alert-success">@TempData["CartMessage"]</div>
    }

    @if (Model.Count == 0)
    {
        <p>No products are enrolled in the trade program yet. Check back soon.</p>
    }
    else
    {
        <table class="table bg-white align-middle">
            <thead>
                <tr>
                    <th></th>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Retail Price</th>
                    <th>Your Price</th>
                    <th>You Save</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    var savingsPct = product.WholesalePrice.HasValue && product.Price > 0
                        ? Math.Round((1 - (product.WholesalePrice.Value / product.Price)) * 100, 0)
                        : 0;
                    <tr>
                        <td><img src="@product.ImageUrl" style="width:56px;height:56px;object-fit:cover;border-radius:4px;" /></td>
                        <td><a asp-controller="Products" asp-action="Details" asp-route-slug="@product.Slug">@product.Name</a></td>
                        <td>@product.Category?.Name</td>
                        <td class="text-muted"><s>@product.Price.ToAed()</s></td>
                        <td class="fw-bold">@product.WholesalePrice!.Value.ToAed()</td>
                        <td><span class="badge badge-status-delivered">-@savingsPct%</span></td>
                        <td>
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-primary">Add to Cart</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
