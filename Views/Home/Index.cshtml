@using WorldLinkMaster.Web.Models
@using WorldLinkMaster.Web.Extensions
@model List<Product>
@{
    ViewData["Title"] = "World Link Master";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var showcaseEvents = ViewBag.ShowcaseEvents as List<PromoEvent> ?? new List<PromoEvent>();
    var bestSellers = ViewBag.BestSellers as List<Product> ?? new List<Product>();
    var trendingProducts = ViewBag.TrendingProducts as List<Product> ?? new List<Product>();
    var todayForEvents = DateTime.UtcNow.Date;
}

<!-- Step 2 — Hero banner: slogan + search bar + primary CTA -->
<section class="hero">
    <div class="container">
        <div class="hero-logo">
            <img src="~/images/logo.png" alt="World Link Masters" />
        </div>
        <span class="hero-eyebrow">@Localizer["Welcome to World Link Master"]</span>
        <h1>@Localizer["Gear Built for the"] <span class="accent">@Localizer["Long Haul"]</span></h1>
        <p>@Localizer["Wherever the mission takes you, we've got you covered. Browse field-tested apparel, packs, footwear, and equipment chosen for durability, function, and value — and built to earn your trust from the first order."]</p>
        <form class="hero-search-form" asp-controller="Products" asp-action="Index" method="get">
            <input type="text" name="search" class="hero-search-input" placeholder="@Localizer["Search gear, apparel, footwear..."]" />
            <button type="submit" class="hero-search-btn"><i class="bi bi-search"></i> @Localizer["Search"]</button>
        </form>
        <div class="mt-4">
            <a class="btn-wlm" asp-controller="Products" asp-action="Index">@Localizer["Start Shopping With Us"]</a>
            <a class="btn-wlm-outline ms-2" asp-controller="QuoteRequests" asp-action="Create">@Localizer["Request a Quote"]</a>
        </div>
    </div>
</section>

<div class="container">
    <div class="trust-strip">
        <div class="trust-item">
            <i class="bi bi-truck"></i>
            <div>
                <strong>@Localizer["Free Shipping"]</strong>
                <span>@Localizer["On all orders over AED 365"]</span>
            </div>
        </div>
        <div class="trust-item">
            <i class="bi bi-shield-check"></i>
            <div>
                <strong>@Localizer["Field-Tested Quality"]</strong>
                <span>@Localizer["Durability you can rely on"]</span>
            </div>
        </div>
        <div class="trust-item">
            <i class="bi bi-arrow-repeat"></i>
            <div>
                <strong>@Localizer["Easy Returns"]</strong>
                <span>@Localizer["Hassle-free 30-day policy"]</span>
            </div>
        </div>
        <div class="trust-item">
            <i class="bi bi-lock"></i>
            <div>
                <strong>@Localizer["Secure Checkout"]</strong>
                <span>@Localizer["Your information stays safe"]</span>
            </div>
        </div>
    </div>
</div>

<!-- Step 4 — Marketing / promotional message: live sale events, discounts, clearance -->
@if (showcaseEvents.Count > 0)
{
    <div class="container">
        <div class="section-title">
            <h2>🎉 @Localizer["Upcoming Sales & Events in the UAE"]</h2>
            <span class="text-muted">@Localizer["Every celebration is a reason to gear up for less."]</span>
        </div>
        <div class="promo-event-row">
            @foreach (var promoEvent in showcaseEvents)
            {
                var isLive = promoEvent.StartDate <= todayForEvents && promoEvent.EndDate >= todayForEvents;
                var daysToStart = (promoEvent.StartDate - todayForEvents).Days;
                var daysToEnd = (promoEvent.EndDate - todayForEvents).Days;
                <div class="promo-event-card @(isLive ? "is-live" : "")">
                    @if (isLive)
                    {
                        <span class="promo-live-badge"><span class="promo-live-dot"></span> @Localizer["LIVE NOW"]</span>
                    }
                    else
                    {
                        <span class="promo-soon-badge">@Localizer["In {0} day(s)", daysToStart]</span>
                    }
                    <span class="promo-event-icon">@promoEvent.IconEmoji</span>
                    <h4>@promoEvent.Name</h4>
                    @if (!string.IsNullOrWhiteSpace(promoEvent.Description))
                    {
                        <p>@promoEvent.Description</p>
                    }
                    <span class="promo-event-discount">@promoEvent.DiscountPercent.ToString("0.##")% @Localizer["OFF (badge)"]</span>
                    <span class="promo-event-dates">
                        @promoEvent.StartDate.ToString("MMM d") &ndash; @promoEvent.EndDate.ToString("MMM d, yyyy")
                        @if (isLive)
                        {
                            <text> &middot; @Localizer["ends in {0} day(s)", daysToEnd]</text>
                        }
                    </span>
                    <a class="promo-event-cta" asp-controller="Products" asp-action="Index">@Localizer["Shop the Sale"] <i class="bi bi-arrow-right"></i></a>
                </div>
            }
        </div>
    </div>
}

<!-- Step 3 — Main products section: curated categories + featured gear, brand slogan already in hero -->
<div class="container">
    <h2 class="collections-title">@Localizer["Collections"]</h2>
    <div class="collections-grid">
        @foreach (var category in categories)
        {
            <a class="collections-tile" asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id">
                <img src="@category.ImageUrl" alt="@category.LocalizedName()" />
                <span class="collections-tile-label">@category.LocalizedName()</span>
            </a>
        }
    </div>
</div>

@if (Model.Count > 0)
{
    var spotlight = Model[0];
    <section class="spotlight-banner" style="background-image: url('@spotlight.ImageUrl')">
        <div class="container">
            <div class="spotlight-content">
                <span class="spotlight-badge">@Localizer["Featured"]</span>
                <h2>@spotlight.LocalizedName()</h2>
                <a class="spotlight-cta" asp-controller="Products" asp-action="Details" asp-route-slug="@spotlight.Slug">@Localizer["Shop Now"]</a>
            </div>
        </div>
    </section>
}

<div class="container">
    <div class="section-title">
        <h2>@Localizer["Featured Gear"]</h2>
        <a asp-controller="Products" asp-action="Index">@Localizer["View All"] &rarr;</a>
    </div>
    <div class="product-grid">
        @foreach (var product in Model)
        {
            <partial name="_ProductCard" model="product" />
        }
    </div>

    @if (bestSellers.Count > 0)
    {
        <!-- Step 4 (continued) — highlight special / best-selling products -->
        <div class="best-selling-section">
            <span class="best-selling-eyebrow">@Localizer["Best Selling"]</span>
            <h2 class="best-selling-heading">@Localizer["Field-Tested Favorites"]</h2>
            <div class="product-carousel">
                <button type="button" class="product-carousel-arrow product-carousel-prev" aria-label="@Localizer["Previous"]"><i class="bi bi-chevron-left"></i></button>
                <div class="product-carousel-track">
                    @foreach (var product in bestSellers)
                    {
                        <div class="product-carousel-item">
                            <partial name="_ProductCard" model="product" />
                        </div>
                    }
                </div>
                <button type="button" class="product-carousel-arrow product-carousel-next" aria-label="@Localizer["Next"]"><i class="bi bi-chevron-right"></i></button>
            </div>
            <div class="text-center">
                <a class="btn-wlm" asp-controller="Products" asp-action="Index">@Localizer["See All Best Sellers"]</a>
            </div>
        </div>
    }

    @if (trendingProducts.Count > 0)
    {
        <!-- Step 5 — Variety products section: trending / popular picks, assorted listings -->
        <div class="section-title">
            <h2>@Localizer["Trending Now"]</h2>
            <a asp-controller="Products" asp-action="Index">@Localizer["View All"] &rarr;</a>
        </div>
        <div class="product-grid">
            @foreach (var product in trendingProducts)
            {
                <partial name="_ProductCard" model="product" />
            }
        </div>
    }
</div>

<!-- Step 6 — Delivery info, policies, and contact/shipping coordination -->
<div class="container">
    <div class="info-strip">
        <div class="info-strip-item">
            <i class="bi bi-truck"></i>
            <h5>@Localizer["Delivery Across the UAE"]</h5>
            <p>@Localizer["We deliver to all seven emirates, with free shipping on orders over AED 365 and tracked delivery on every order."]</p>
        </div>
        <div class="info-strip-item">
            <i class="bi bi-file-earmark-text"></i>
            <h5>@Localizer["Policies & Terms"]</h5>
            <p>@Localizer["Read our"] <a asp-controller="Home" asp-action="Privacy">@Localizer["Privacy Policy"]</a> @Localizer["and"] <a asp-controller="Home" asp-action="About">@Localizer["About Us"]</a> @Localizer["pages for our full terms and return policy."]</p>
        </div>
        <div class="info-strip-item">
            <i class="bi bi-headset"></i>
            <h5>@Localizer["Contact & Shipping Coordination"]</h5>
            <p>
                <i class="bi bi-telephone"></i> 1-800-555-0199<br />
                <i class="bi bi-envelope"></i> support@worldlinkmaster.com
            </p>
            <a asp-controller="Home" asp-action="Contact">@Localizer["Contact Us"] <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
</div>
