@{
    ViewData["Title"] = "Contact Us";
}
<div class="page-banner">
    <div class="container"><h1>Contact Us</h1></div>
</div>
<div class="container mb-5">
    <div class="row g-4">
        <div class="col-12 col-md-6">
            <h5>Customer Support</h5>
            <p><i class="bi bi-telephone"></i> 1-800-555-0199</p>
            <p><i class="bi bi-envelope"></i> support@worldlinkmaster.com</p>
            <p><i class="bi bi-clock"></i> Mon-Fri, 8am - 6pm EST</p>
        </div>
        <div class="col-12 col-md-6">
            <h5>Send us a message</h5>
            <form onsubmit="return false;">
                <div class="mb-3">
                    <input type="text" class="form-control" placeholder="Your name" required />
                </div>
                <div class="mb-3">
                    <input type="email" class="form-control" placeholder="Your email" required />
                </div>
                <div class="mb-3">
                    <textarea class="form-control" rows="4" placeholder="How can we help?" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Send Message</button>
            </form>
        </div>
    </div>
</div>
