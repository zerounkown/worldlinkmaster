@{
    ViewData["Title"] = Localizer["About Us"];
}
<div class="page-banner">
    <div class="container"><h1>@Localizer["About World Link Master"]</h1></div>
</div>
<div class="container mb-5">
    <div class="row">
        <div class="col-12 col-md-8">
            <p class="lead">@Localizer["World Link Master was founded on a simple idea: gear should work as hard as the people who rely on it."]</p>
            <p>@Localizer["From tactical apparel to trail-ready packs and boots, every product we carry is chosen for durability, function, and value. We work directly with manufacturers to cut out the markup and pass the savings on to operators, adventurers, and everyday professionals alike."]</p>
            <p>@Localizer["Whether you're heading into the field, the backcountry, or just need gear you can trust every day, World Link Master has you covered."]</p>
        </div>
    </div>
</div>
