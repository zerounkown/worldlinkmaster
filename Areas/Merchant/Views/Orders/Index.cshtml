@using WorldLinkMaster.Web.Models
@model List<OrderItem>
@{
    ViewData["Title"] = Localizer["My Orders"];
    var payouts = ViewBag.Payouts as Dictionary<int, MerchantPayout> ?? new Dictionary<int, MerchantPayout>();
}

<h1>@Localizer["My Orders"]</h1>

<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead><tr><th>@Localizer["Order #"]</th><th>@Localizer["Date"]</th><th>@Localizer["Product"]</th><th>@Localizer["Options"]</th><th>@Localizer["Qty"]</th><th>@Localizer["Line Total"]</th><th>@Localizer["Payout Status"]</th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            var payout = payouts.TryGetValue(item.OrderId, out var p) ? p : null;
            <tr>
                <td>#@item.OrderId</td>
                <td>@item.Order?.OrderDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                <td>@item.ProductName</td>
                <td class="text-muted small">@item.Color @(!string.IsNullOrEmpty(item.Color) && !string.IsNullOrEmpty(item.Size) ? " / " : "") @item.Size</td>
                <td>@item.Quantity</td>
                <td>@item.LineTotal.ToAed()</td>
                <td>@(payout != null ? Localizer[payout.Status.ToString()] : Localizer["Pending"])</td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="7" class="text-muted">@Localizer["No orders yet."]</td></tr>
        }
    </tbody>
</table>
</div>
