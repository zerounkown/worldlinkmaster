@using WorldLinkMaster.Web.Models
@model List<Product>
@{
    ViewData["Title"] = Localizer["My Products"];
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@Localizer["My Products"]</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> @Localizer["New Product"]</a>
</div>

<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead>
        <tr><th></th><th>@Localizer["Name"]</th><th>@Localizer["Category"]</th><th>@Localizer["Price"]</th><th>@Localizer["Wholesale"]</th><th>@Localizer["Stock"]</th><th>@Localizer["Featured"]</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td><img src="@product.ImageUrl" style="width:48px;height:48px;object-fit:cover;border-radius:4px;" /></td>
                <td>@product.Name</td>
                <td>@product.Category?.Name</td>
                <td>@product.Price.ToAed()</td>
                <td>@(product.WholesalePrice.HasValue ? product.WholesalePrice.Value.ToAed() : "—")</td>
                <td>@product.StockQuantity</td>
                <td>@(product.IsFeatured ? Localizer["Yes"].Value : "")</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@product.Id">@Localizer["Edit"]</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.Id">@Localizer["Delete"]</a>
                </td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="8" class="text-muted">@Localizer["You haven't listed any products yet."]</td></tr>
        }
    </tbody>
</table>
</div>
