@using WorldLinkMaster.Web.Models
@model Order
@{
    ViewData["Title"] = Localizer["Order #{0}", Model.Id];
}

<h1>@Localizer["Order #{0}", Model.Id]</h1>
<p>@Localizer["Customer:"] @Model.User?.Email</p>

<div class="row">
    <div class="col-12 col-md-7">
        <div class="table-responsive">
        <table class="table bg-white">
            <thead><tr><th>@Localizer["Product"]</th><th>@Localizer["Options"]</th><th>@Localizer["Price"]</th><th>@Localizer["Qty"]</th><th>@Localizer["Total"]</th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td class="text-muted small">@item.Color @(!string.IsNullOrEmpty(item.Color) && !string.IsNullOrEmpty(item.Size) ? " / " : "") @item.Size</td>
                        <td>@item.UnitPrice.ToAed()</td>
                        <td>@item.Quantity</td>
                        <td>@item.LineTotal.ToAed()</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
    <div class="col-12 col-md-5">
        <div class="summary-box">
            <h4>@Localizer["Summary"]</h4>
            <div class="d-flex justify-content-between mb-2"><span>@Localizer["Subtotal"]</span><span>@Model.Subtotal.ToAed()</span></div>
            <div class="d-flex justify-content-between mb-2"><span>@Localizer["Shipping"]</span><span>@(Model.ShippingCost == 0 ? Localizer["Free"].Value : Model.ShippingCost.ToAed())</span></div>
            <hr />
            <div class="d-flex justify-content-between fw-bold"><span>@Localizer["Total"]</span><span>@Model.Total.ToAed()</span></div>
            <hr />
            <p>@Localizer["Shipping to:"]<br />@Model.ShippingName<br />@Model.ShippingAddress<br />@Model.ShippingCity, @Model.ShippingState @Model.ShippingZip<br />@Model.ShippingPhone</p>

            <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 mt-3">
                <select name="status" class="form-select">
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        <option value="@status" selected="@(status == Model.Status)">@Localizer[status.ToString()]</option>
                    }
                </select>
                <button type="submit" class="btn btn-primary">@Localizer["Update"]</button>
            </form>
        </div>
    </div>
</div>

<a class="mt-3 d-inline-block" asp-action="Index">&larr; @Localizer["Back to Orders"]</a>
