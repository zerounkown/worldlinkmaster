@using WorldLinkMaster.Web.Models
@model Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<h1>Order #@Model.Id</h1>
<p>Customer: @Model.User?.Email</p>

<div class="row">
    <div class="col-12 col-md-7">
        <div class="table-responsive">
        <table class="table bg-white">
            <thead><tr><th>Product</th><th>Options</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td class="text-muted small">@item.Color @(!string.IsNullOrEmpty(item.Color) && !string.IsNullOrEmpty(item.Size) ? " / " : "") @item.Size</td>
                        <td>@item.UnitPrice.ToAed()</td>
                        <td>@item.Quantity</td>
                        <td>@item.LineTotal.ToAed()</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
    <div class="col-12 col-md-5">
        <div class="summary-box">
            <h4>Summary</h4>
            <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><span>@Model.Subtotal.ToAed()</span></div>
            <div class="d-flex justify-content-between mb-2"><span>Shipping</span><span>@(Model.ShippingCost == 0 ? "Free" : Model.ShippingCost.ToAed())</span></div>
            <hr />
            <div class="d-flex justify-content-between fw-bold"><span>Total</span><span>@Model.Total.ToAed()</span></div>
            <hr />
            <p>Shipping to:<br />@Model.ShippingName<br />@Model.ShippingAddress<br />@Model.ShippingCity, @Model.ShippingState @Model.ShippingZip<br />@Model.ShippingPhone</p>

            <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 mt-3">
                <select name="status" class="form-select">
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        <option value="@status" selected="@(status == Model.Status)">@status</option>
                    }
                </select>
                <button type="submit" class="btn btn-primary">Update</button>
            </form>
        </div>
    </div>
</div>

<a class="mt-3 d-inline-block" asp-action="Index">&larr; Back to Orders</a>
