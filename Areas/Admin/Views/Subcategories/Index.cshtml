@using WorldLinkMaster.Web.Models
@model List<Subcategory>
@{
    ViewData["Title"] = Localizer["Manage Subcategories"];
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@Localizer["Subcategories"]</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> @Localizer["New Subcategory"]</a>
</div>

<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead><tr><th>@Localizer["Category"]</th><th>@Localizer["Name"]</th><th>@Localizer["Slug"]</th><th>@Localizer["Products"]</th><th></th></tr></thead>
    <tbody>
        @foreach (var subcategory in Model)
        {
            <tr>
                <td>@subcategory.Category?.Name</td>
                <td>@subcategory.Name</td>
                <td>@subcategory.Slug</td>
                <td>@subcategory.Products.Count</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@subcategory.Id">@Localizer["Edit"]</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@subcategory.Id">@Localizer["Delete"]</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
