@using WorldLinkMaster.Web.Models.ViewModels
@model List<CustomerListItemViewModel>
@{
    ViewData["Title"] = Localizer["Manage Customers"];
}

<h1>@Localizer["Customers"]</h1>
<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead><tr><th>@Localizer["Name"]</th><th>@Localizer["Email"]</th><th>@Localizer["Roles"]</th><th>@Localizer["Orders"]</th><th>@Localizer["Status"]</th><th></th></tr></thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@(string.IsNullOrWhiteSpace(customer.FullName) ? "—" : customer.FullName)</td>
                <td>@customer.Email</td>
                <td>
                    @foreach (var role in customer.Roles)
                    {
                        <span class="badge bg-secondary me-1">@role</span>
                    }
                </td>
                <td>@customer.OrderCount</td>
                <td>
                    @if (customer.LockedOut)
                    {
                        <span class="badge bg-danger">@Localizer["Locked"]</span>
                    }
                    else if (!customer.EmailConfirmed)
                    {
                        <span class="badge bg-warning text-dark">@Localizer["Unconfirmed"]</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@Localizer["Active"]</span>
                    }
                </td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@customer.Id">@Localizer["View"]</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@customer.Id">@Localizer["Edit"]</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@customer.Id">@Localizer["Delete"]</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
