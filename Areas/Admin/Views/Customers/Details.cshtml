@using WorldLinkMaster.Web.Models.ViewModels
@model CustomerDetailsViewModel
@{
    ViewData["Title"] = Localizer["Customer Details"];
    var fullName = $"{Model.User.FirstName} {Model.User.LastName}".Trim();
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@(string.IsNullOrWhiteSpace(fullName) ? Model.User.Email : fullName)</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.User.Id"><i class="bi bi-pencil"></i> @Localizer["Edit"]</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.User.Id"><i class="bi bi-trash"></i> @Localizer["Delete"]</a>
    </div>
</div>

<div class="row g-3 my-1">
    <div class="col-12 col-md-6">
        <div class="summary-box">
            <h4>@Localizer["Account"]</h4>
            <p class="mb-1"><strong>@Localizer["Email:"]</strong> @Model.User.Email</p>
            <p class="mb-1"><strong>@Localizer["Phone:"]</strong> @(Model.User.PhoneNumber ?? "—")</p>
            <p class="mb-1">
                <strong>@Localizer["Roles:"]</strong>
                @if (Model.Roles.Count == 0)
                {
                    <span class="text-muted">@Localizer["None"]</span>
                }
                else
                {
                    foreach (var role in Model.Roles)
                    {
                        <span class="badge bg-secondary me-1">@role</span>
                    }
                }
            </p>
            <p class="mb-1"><strong>@Localizer["Email confirmed:"]</strong> @(Model.User.EmailConfirmed ? Localizer["Yes"].Value : Localizer["No"].Value)</p>
            <p class="mb-0">
                <strong>@Localizer["Status:"]</strong>
                @if (Model.LockedOut)
                {
                    <span class="badge bg-danger">@Localizer["Locked"]</span>
                }
                else
                {
                    <span class="badge bg-success">@Localizer["Active"]</span>
                }
            </p>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="summary-box">
            <h4>@Localizer["Other Profiles"]</h4>
            @if (Model.MerchantProfile != null)
            {
                <p class="mb-1"><strong>@Localizer["Merchant:"]</strong> @Model.MerchantProfile.BusinessName</p>
            }
            @if (Model.WholesaleAccount != null)
            {
                <p class="mb-1"><strong>@Localizer["Wholesale account:"]</strong> @Model.WholesaleAccount.CompanyName</p>
            }
            @if (Model.MerchantProfile == null && Model.WholesaleAccount == null)
            {
                <p class="text-muted mb-1">@Localizer["No merchant or wholesale profile."]</p>
            }
            <p class="mb-0"><strong>@Localizer["Coupons issued:"]</strong> @Model.CouponCount</p>
        </div>
    </div>
</div>

<h4 class="mt-4">@Localizer["Orders ({0})", Model.Orders.Count]</h4>
<div class="table-responsive">
<table class="table bg-white align-middle">
    <thead><tr><th>@Localizer["Order #"]</th><th>@Localizer["Date"]</th><th>@Localizer["Status"]</th><th>@Localizer["Total"]</th><th></th></tr></thead>
    <tbody>
        @if (Model.Orders.Count == 0)
        {
            <tr><td colspan="5" class="text-muted">@Localizer["No orders yet."]</td></tr>
        }
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.OrderDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                <td><span class="badge badge-status-@order.Status.ToString().ToLower()">@Localizer[order.Status.ToString()]</span></td>
                <td>@order.Total.ToAed()</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id">@Localizer["View"]</a></td>
            </tr>
        }
    </tbody>
</table>
</div>

<a class="mt-3 d-inline-block" asp-action="Index">&larr; @Localizer["Back to Customers"]</a>
