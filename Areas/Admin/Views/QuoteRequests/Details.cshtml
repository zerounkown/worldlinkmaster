@using WorldLinkMaster.Web.Models
@model QuoteRequest
@{
    ViewData["Title"] = Localizer["Quote Request Details"];
    var requestNumber = $"WLM-Q-{Model.Id:D6}";
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@requestNumber</h1>
    <span class="badge bg-@(Model.Status switch { QuoteStatus.Pending => "warning text-dark", QuoteStatus.Quoted => "info text-dark", QuoteStatus.Approved => "success", QuoteStatus.Rejected => "danger", _ => "secondary" }) fs-6">@Localizer[Model.Status.ToString()]</span>
</div>

<div class="row g-3 my-1">
    <div class="col-12 col-md-6">
        <div class="summary-box">
            <h4>@Localizer["Contact Info"]</h4>
            <p class="mb-1"><strong>@Localizer["Company Name"]:</strong> @Model.CompanyName</p>
            <p class="mb-1"><strong>@Localizer["Email"]:</strong> @Model.Email</p>
            <p class="mb-1"><strong>@Localizer["Phone"]:</strong> @Model.Phone</p>
            <p class="mb-1"><strong>@Localizer["Trade License Number (optional)"]:</strong> @(string.IsNullOrWhiteSpace(Model.TradeLicenseNumber) ? "—" : Model.TradeLicenseNumber)</p>
            <p class="mb-0"><strong>@Localizer["Submitted:"]</strong> @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</p>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="summary-box">
            <h4>@Localizer["Product / Service Details"]</h4>
            <p class="mb-1"><strong>@Localizer["Quantity"]:</strong> @Model.Quantity</p>
            <p class="mb-0" style="white-space: pre-wrap;">@Model.ProductDetails</p>
        </div>
    </div>
</div>

@if (Model.RespondedAt.HasValue)
{
    <div class="summary-box mt-3">
        <h4>@Localizer["Last Response"]</h4>
        @if (Model.QuotedPrice.HasValue)
        {
            <p class="mb-1"><strong>@Localizer["Quoted Price"]:</strong> @Model.QuotedPrice.Value.ToAed()</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.AdminNotes))
        {
            <p class="mb-1" style="white-space: pre-wrap;"><strong>@Localizer["Response to Customer"]:</strong><br />@Model.AdminNotes</p>
        }
        <p class="mb-0 text-muted small">@Localizer["Responded:"] @Model.RespondedAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</p>
    </div>
}

<div class="summary-box mt-3">
    <h4>@Localizer["Update Status"]</h4>
    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
        <div class="row">
            <div class="col-12 col-sm-6 mb-3">
                <label class="form-label">@Localizer["Status"]</label>
                <select name="status" class="form-select">
                    @foreach (var status in Enum.GetValues<QuoteStatus>())
                    {
                        <option value="@status" selected="@(status == Model.Status)">@Localizer[status.ToString()]</option>
                    }
                </select>
            </div>
            <div class="col-12 col-sm-6 mb-3">
                <label class="form-label">@Localizer["Quoted Price (AED)"]</label>
                <input type="number" step="0.01" min="0" name="quotedPrice" class="form-control" value="@Model.QuotedPrice" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">@Localizer["Response to Customer"]</label>
            <textarea name="adminNotes" class="form-control" rows="4">@Model.AdminNotes</textarea>
        </div>
        <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
    </form>
</div>

<a class="mt-3 d-inline-block" asp-action="Index">&larr; @Localizer["Back to Quote Requests"]</a>
