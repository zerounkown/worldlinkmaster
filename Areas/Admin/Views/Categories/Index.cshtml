@using WorldLinkMaster.Web.Models
@model List<Category>
@{
    ViewData["Title"] = Localizer["Manage Categories"];
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@Localizer["Categories"]</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> @Localizer["New Category"]</a>
</div>

<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead><tr><th></th><th>@Localizer["Name"]</th><th>@Localizer["Slug"]</th><th>@Localizer["Products"]</th><th></th></tr></thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td><img src="@category.ImageUrl" style="width:48px;height:48px;object-fit:cover;border-radius:4px;" /></td>
                <td>@category.Name</td>
                <td>@category.Slug</td>
                <td>@category.Products.Count</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@category.Id">@Localizer["Edit"]</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@category.Id">@Localizer["Delete"]</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
