@using WorldLinkMaster.Web.Models
@model List<Coupon>
@{
    ViewData["Title"] = Localizer["Coupons"];
    var now = DateTime.UtcNow;
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@Localizer["Promo Coupons"]</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> @Localizer["New Coupon"]</a>
</div>
<p class="text-muted">@Localizer["Public discount codes any customer can enter at checkout. Each customer can redeem a given code once, within its date window and up to its redemption limit."]</p>

<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead><tr><th>@Localizer["Code"]</th><th>@Localizer["Discount"]</th><th>@Localizer["Window"]</th><th>@Localizer["Redemptions"]</th><th>@Localizer["Status"]</th><th></th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            var notStarted = c.StartsAt.HasValue && c.StartsAt.Value > now;
            var expired = c.ExpiresAt.HasValue && c.ExpiresAt.Value < now;
            var maxedOut = c.MaxRedemptions.HasValue && c.RedemptionCount >= c.MaxRedemptions.Value;
            var status = !c.IsActive ? (Localizer["Disabled"], "secondary")
                : notStarted ? (Localizer["Scheduled"], "warning")
                    : expired ? (Localizer["Expired"], "secondary")
                        : maxedOut ? (Localizer["Fully redeemed"], "secondary")
                            : (Localizer["Live"], "success");
            <tr>
                <td>
                    <strong>@c.Code</strong>
                    @if (!string.IsNullOrWhiteSpace(c.Description))
                    {
                        <br /><small class="text-muted">@c.Description</small>
                    }
                </td>
                <td>@c.DiscountPercent.ToString("0.##")% @Localizer["OFF (badge)"]</td>
                <td>@(c.StartsAt?.ToString("MMM d, yyyy") ?? Localizer["Any time"].Value) &rarr; @(c.ExpiresAt?.ToString("MMM d, yyyy") ?? Localizer["No expiry"].Value)</td>
                <td>@c.RedemptionCount@(c.MaxRedemptions.HasValue ? $" / {c.MaxRedemptions}" : "")</td>
                <td><span class="badge bg-@status.Item2">@status.Item1</span></td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id">@Localizer["Edit"]</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.Id">@Localizer["Delete"]</a>
                </td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="6" class="text-muted">@Localizer["No promo coupons yet. Create one for customers to use at checkout."]</td></tr>
        }
    </tbody>
</table>
</div>
