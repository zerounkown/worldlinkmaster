@using WorldLinkMaster.Web.Models
@model List<Product>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex justify-content-between align-items-center">
    <h1>Products</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> New Product</a>
</div>

<table class="table bg-white align-middle mt-3">
    <thead>
        <tr><th></th><th>Name</th><th>Category</th><th>Price</th><th>Wholesale</th><th>Stock</th><th>Featured</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td><img src="@product.ImageUrl" style="width:48px;height:48px;object-fit:cover;border-radius:4px;" /></td>
                <td>@product.Name</td>
                <td>@product.Category?.Name</td>
                <td>@product.Price.ToAed()</td>
                <td>@(product.WholesalePrice.HasValue ? product.WholesalePrice.Value.ToAed() : "—")</td>
                <td>@product.StockQuantity</td>
                <td>@(product.IsFeatured ? "Yes" : "")</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@product.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
