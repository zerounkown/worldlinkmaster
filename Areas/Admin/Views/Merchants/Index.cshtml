@using WorldLinkMaster.Web.Models
@model List<Merchant>
@{
    ViewData["Title"] = Localizer["Merchants"];
}

<h1>@Localizer["Merchants"]</h1>

<div class="table-responsive">
<table class="table bg-white align-middle mt-3">
    <thead><tr><th>@Localizer["Business"]</th><th>@Localizer["Contact Info"]</th><th>@Localizer["Products"]</th><th>@Localizer["Stripe Status"]</th><th>@Localizer["Joined"]</th></tr></thead>
    <tbody>
        @foreach (var merchant in Model)
        {
            <tr>
                <td>@merchant.BusinessName</td>
                <td>@merchant.User?.Email</td>
                <td>@merchant.Products.Count</td>
                <td>
                    @if (merchant.StripeOnboardingComplete)
                    {
                        <span class="badge badge-status-delivered">@Localizer["Connected"]</span>
                    }
                    else if (!string.IsNullOrEmpty(merchant.StripeAccountId))
                    {
                        <span class="badge badge-status-processing">@Localizer["Onboarding started"]</span>
                    }
                    else
                    {
                        <span class="badge badge-status-pending">@Localizer["Not connected"]</span>
                    }
                </td>
                <td>@merchant.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="5" class="text-muted">@Localizer["No merchants yet."]</td></tr>
        }
    </tbody>
</table>
</div>
